# ==============================================================================
# Core Settings
# ==============================================================================

# The log level for the application. Supported values are `DEBUG`, `INFO`, `WARNING`, `ERROR`, `CRITICAL`.
LOG_LEVEL=INFO

# A secret key for verifying the integrity of signed cookies.
# You can generate a strong key using `openssl rand -base64 42`.
SECRET_KEY=your-secret-key-here

# The base URL of the console application, used to generate the correct URL in the email notification.
CONSOLE_WEB_URL=http://localhost/console

# The base URL of the web application, used to generate the correct URL in the email notification.
APP_WEB_URL=http://localhost

# The base URL of the service API, used to generate the correct URL in the email notification.
SERVICE_API_URL=http://localhost/v1

# ==============================================================================
# Database Settings
# ==============================================================================

# The username of the database.
DB_USERNAME=postgres

# The password of the database.
DB_PASSWORD=difyai123456

# The host of the database.
DB_HOST=db

# The port of the database.
DB_PORT=5432

# The database name for the console application.
DB_DATABASE=dify

# The database URL for the console application.
# If you want to use the external database, please change the following URL to your database URL.
DATABASE_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}

# The database name for the cache.
DB_DATABASE_CACHE=dify_cache

# The database URL for the cache.
# If you want to use the external database, please change the following URL to your database URL.
CACHE_DB_URL=postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE_CACHE}

# The database pool size for the console application.
# The number of connections to keep open in the database connection pool.
DB_POOL_SIZE=30

# The database pool size for the cache.
# The number of connections to keep open in the database connection pool.
CACHE_DB_POOL_SIZE=30

# ==============================================================================
# Redis Settings
# ==============================================================================

# The host of the Redis.
REDIS_HOST=redis

# The port of the Redis.
REDIS_PORT=6379

# The username of the Redis.
REDIS_USERNAME=

# The password of the Redis.
REDIS_PASSWORD=difyai123456

# The database URL for the Redis.
# If you want to use the external Redis, please change the following URL to your Redis URL.
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# The database URL for the Redis cache.
# If you want to use the external Redis, please change the following URL to your Redis URL.
REDIS_DB_CACHE_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/1

# ==============================================================================
# Celery Settings
# ==============================================================================

# The broker URL for the Celery.
# If you want to use the external Redis, please change the following URL to your Redis URL.
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/2

# The result backend URL for the Celery.
# If you want to use the external Redis, please change the following URL to your Redis URL.
CELERY_RESULT_BACKEND_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/3

# ==============================================================================
# Storage Settings
# ==============================================================================

# The type of the storage. Supported values are `local`, `s3`, `azure-blob`, `google-storage`.
STORAGE_TYPE=local

# The local path of the storage.
STORAGE_LOCAL_PATH=storage

# The AWS S3 settings.
# If you want to use the AWS S3, please change the following settings.
S3_ENDPOINT=https://your-s3-endpoint
S3_BUCKET=your-s3-bucket
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_REGION=us-east-1

# The Azure Blob Storage settings.
# If you want to use the Azure Blob Storage, please change the following settings.
AZURE_BLOB_ACCOUNT_NAME=your-azure-blob-account-name
AZURE_BLOB_ACCOUNT_KEY=your-azure-blob-account-key
AZURE_BLOB_CONTAINER_NAME=your-azure-blob-container-name
AZURE_BLOB_ACCOUNT_URL=https://your-azure-blob-account-url

# The Google Cloud Storage settings.
# If you want to use the Google Cloud Storage, please change the following settings.
GOOGLE_STORAGE_BUCKET_NAME=your-google-storage-bucket-name

# ==============================================================================
# Vector Database Settings
# ==============================================================================

# The type of the vector database. Supported values are `qdrant`, `weaviate`, `milvus`, `pgvector`, `chroma`, `opensearch`, `tencent`.
VECTOR_STORE=qdrant

# The Qdrant settings.
# If you want to use the Qdrant, please change the following settings.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-api-key

# The Weaviate settings.
# If you want to use the Weaviate, please change the following settings.
WEAVIATE_ENDPOINT=http://weaviate:8080
WEAVIATE_API_KEY=your-weaviate-api-key

# The Milvus settings.
# If you want to use the Milvus, please change the following settings.
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_SECURE=false

# The Chroma settings.
# If you want to use the Chroma, please change the following settings.
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=/chroma

# The OpenSearch settings.
# If you want to use the OpenSearch, please change the following settings.
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_SECURE=false

# The Tencent Vector Database settings.
# If you want to use the Tencent Vector Database, please change the following settings.
TENCENT_VECTOR_DB_URL=http://your-tencent-vector-db-url
TENCENT_VECTOR_DB_API_KEY=your-tencent-vector-db-api-key
TENCENT_VECTOR_DB_TIMEOUT=30
TENCENT_VECTOR_DB_DATABASE=your-tencent-vector-db-database

